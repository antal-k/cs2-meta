# Steam credentials (optional — anonymous login works for public depots)
# STEAM_USERNAME=
# STEAM_PASSWORD=

# Force re-download on every run
# FORCE_DOWNLOAD=true

# ── Bunny CDN ──
# BUNNY_ACCESS_KEY=
# BUNNY_STORAGE_ZONE_NAME=
# BUNNY_STORAGE_REGION=

# ── S3 / S3-compatible (R2, MinIO, DigitalOcean Spaces) ──
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=
# S3_ENDPOINT=
